# ===========================================
# FICHIER: .env.example
# RÔLE: Template pour les variables d'environnement
# À DUPLIQUER en .env pour le développement
# ===========================================

# Port du serveur
PORT=8080

# MongoDB Atlas (remplacer par vos identifiants)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/laboratoire

# Clé secrète JWT (à changer en production)
JWT_SECRET=votre_secret_jwt_tres_long_et_difficile

# Environnement
NODE_ENV=development